bindsym $mod+Shift+s exec rofi -show ssh -i3 -lines 10 -sidebar-mode -fg "#9f9f9f" -bg "#2c2c2e" -hlfg "#2c2c2e" -hlbg "#ccdc90" -o 85

# Creates a new workspace on the current monitor. Autoincrements the workspace number
bindsym $mod+Shift+w exec new-workspace.py
